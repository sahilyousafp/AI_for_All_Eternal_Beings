# Environment variables for the Soil Futures pipeline
# Copy this file to .env (which is gitignored) OR set these as system env vars.
# On Windows: setx GEMINI_API_KEY "your-key-here"  then open a new terminal.

# Google AI Studio key for Gemini 2.5 Flash Image ("Nano Banana").
# Get one: https://aistudio.google.com/apikey
# Used by: backend/assets/nano_banana_factory.py
GEMINI_API_KEY=

# Optional: override the Gemini image model if Google renames it later.
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
